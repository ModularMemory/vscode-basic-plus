{
    "comments": {
        // symbol used for single line comment.
        "lineComment": ["*", "//"],
        // symbols used for start and end a block comment.
        "blockComment": [ "/*", "*/" ]
    },
    // symbols used as brackets
    "brackets": [
        ["[", "]"],
        ["(", ")"]
    ],
    // symbols that are auto closed when typing
    "autoClosingPairs": [
        ["[", "]"],
        ["(", ")"],
        { "open": "<", "close": ">", "notIn": ["comment", "string"]},
        { "open": "\"", "close": "\"", "notIn": ["comment", "string"]},
        { "open": "'", "close": "'", "notIn": ["comment", "string"] },
        { "open": "/*", "close": "*/", "notIn": ["comment", "string"] }
    ],
    // symbols that can be used to surround a selection
    "surroundingPairs": [
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    // Folding regions
    "folding": {
		"markers": {
			"start": "^[ \\t]*(?i:#region)\\b",
			"end": "^[ \\t]*(i?:#endregion)\\b"
		}
	},
    // when a new line should be indented or unindented
    // "indentationRules": {
    //     "increaseIndentPattern": "^[ \\t]*(?i:loop|until.+|for.+|.+(?:then|else))[ \\t]*(?:\\*.*)?$",
    //     "decreaseIndentPattern": "^[ \\t]*(?i:end|repeat|next).*?$"
    // }
}