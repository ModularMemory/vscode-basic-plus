{
  "name": "basic-plus",
  "displayName": "Basic+ Support",
  "description": "OpenInsight BASIC+ language and snippets for VSCode",
  "version": "1.0.2",
  "publisher": "modularmemory",
  "author": {
    "name": "ModularMemory",
    "url": "https://github.com/ModularMemory"
  },
  "repository": {
    "url": "https://github.com/ModularMemory/vscode-basic-plus"
  },
  "keywords": ["basic", "basic+", "basic-plus", "basic plus", "openinsight", "open insight"],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [{
      "id": "basic-plus",
      "aliases": ["BASIC+", "basic-plus", "oib"],
      "extensions": [".oib"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "basic-plus",
      "scopeName": "source.oib",
      "path": "./syntaxes/basic-plus.tmLanguage.json"
    }],
    "snippets": [{
        "language": "basic-plus",
        "path": "./snippets/basic-plus.json"
    }]
  }
}
