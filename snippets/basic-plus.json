{
    "For Loop": {
        "prefix": "for",
        "body": [
            "FOR ${2:element} = ${3:start} TO ${1:max}",
            "\t$0",
            "NEXT $2"
        ],
        "description": "A FOR loop."
    },
    "Loop": {
        "prefix": "loop",
        "body": [
            "LOOP",
            "\t$2",
            "UNTIL ${1:condition}",
            "\t$0",
            "REPEAT"
        ],
        "description": "A standard loop."
    },
    "Case": {
        "prefix": "begin case",
        "body": [
            "BEGIN CASE",
            "*@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@",
            "\tCASE $1",
            "*@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@",
            "\t$0",
            "END CASE"
        ]
    },
    "Swap": {
        "prefix": "swap",
        "body": [
            "SWAP ${1:from} WITH ${2:to} IN ${3:element}"
        ],
        "description": "A SWAP statement."
    },
    "Convert": {
        "prefix": "convert",
        "body": [
            "CONVERT ${1:from} TO ${2:to} IN ${3:element}"
        ],
        "description": "A CONVERT statement."
    },
    "If": {
        "prefix": "if",
        "body": [
            "IF ${1:condition} THEN",
            "\t$0",
            "END"
        ],
        "description": "An IF block"
    },
    "If Else": {
        "prefix": "if-else",
        "body": [
            "IF ${1:condition} THEN",
            "\t$3",
            "END ELSE",
            "\t$0",
            "END"
        ],
        "description": "An IF-ELSE block"
    }
}